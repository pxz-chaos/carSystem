# CarFleetSystem production example
# 复制为 .env 后修改。不要把真实密钥发给别人。

SECRET_KEY=please-change-to-a-long-random-secret
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=0

# 本地测试用 console；公网真实短信改为 aliyun
SMS_PROVIDER=console
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
SMS_MAX_ATTEMPTS=5
SMS_CODE_LENGTH=6

# 阿里云短信服务配置。SMS_PROVIDER=aliyun 时必须填写。
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_LOGIN=
ALIYUN_SMS_TEMPLATE_CODE_RESET=
ALIYUN_SMS_TEMPLATE_PARAM_NAME=code


# V8.2 数据自动清理。默认关闭。
# DATA_CLEANUP_AUTO_ENABLED=1 开启自动清理；DATA_RETENTION_MONTHS=6 表示保留最近6个月。
DATA_CLEANUP_AUTO_ENABLED=0
DATA_RETENTION_MONTHS=0
DATA_CLEANUP_BACKUP_BEFORE_DELETE=1
DATA_CLEANUP_DELETE_PHOTOS=1
DATA_CLEANUP_CHECK_INTERVAL_SECONDS=86400

# V8.6 OCR确认/识别率配置
OCR_FALLBACK_ENABLED=1
OCR_MAX_ROI_IMAGES=5
OCR_MIN_AUTO_MILEAGE=1000
OCR_USE_ANGLE_CLS=0
OCR_FAST_MODE=1

# Production upload/image limits
MAX_CONTENT_LENGTH_MB=8
IMAGE_MAX_DIMENSION=1280
IMAGE_JPEG_QUALITY=75
IMAGE_EXPORT_JPEG_QUALITY=85

# Free SMTP password reset. Use an app-specific password/authorization code, not the mailbox login password.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=1
SMTP_USE_TLS=0
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=邮箱授权码
SMTP_FROM_NAME=车辆管理系统
SMTP_FROM_EMAIL=your_email@qq.com

SMTP_TIMEOUT_SECONDS=15
SMTP_DEBUG=1
EMAIL_SMTP_FALLBACK_TO_CONSOLE=1
EMAIL_CODE_LENGTH=6
EMAIL_CODE_TTL_SECONDS=300
EMAIL_SEND_COOLDOWN_SECONDS=60
EMAIL_MAX_ATTEMPTS=5

# Reverse geocoding. Replace email/user-agent with your real contact.
REVERSE_GEOCODE_ENABLED=1
REVERSE_GEOCODE_PROVIDER=nominatim
NOMINATIM_USER_AGENT=CarFleetSystem/1.0 (your_email@example.com)
NOMINATIM_EMAIL=your_email@example.com
REVERSE_GEOCODE_LANGUAGE=zh-CN,zh,en
REVERSE_GEOCODE_COUNTRYCODES=cn

# Email verification code limits
EMAIL_CODE_TTL_SECONDS=300
EMAIL_SEND_COOLDOWN_SECONDS=60
EMAIL_MAX_ATTEMPTS=5

# Reverse geocoding provider. For mainland China, use amap and fill AMAP_WEB_SERVICE_KEY.
REVERSE_GEOCODE_PROVIDER=amap
AMAP_WEB_SERVICE_KEY=your_amap_web_service_key
AMAP_REVERSE_EXTENSIONS=all
AMAP_REVERSE_RADIUS=1000
AMAP_INPUT_COORD_TYPE=wgs84
AMAP_WGS84_TO_GCJ02=1
REVERSE_GEOCODE_FALLBACK_NOMINATIM=0

# SMTP 调试。收不到邮件时可先开 SMTP_DEBUG=1 查看握手和认证过程。
SMTP_TIMEOUT_SECONDS=15
SMTP_DEBUG=0
# 本地/调试兜底：SMTP 失败时将验证码写入 debug_ocr/email_codes.txt；生产环境建议改为 0。
EMAIL_SMTP_FALLBACK_TO_CONSOLE=1
EMAIL_CODE_LENGTH=6
