 ADMIN_ROLE_NAMES = {"管理员", "超级管理员", "admin", "administrator"}
+
+
+USER_PROFILE_SELECT = """
+id,
+username,
+role,
+phone,
+gender,
+CASE WHEN unit='其他' AND COALESCE(unit_other,'')<>'' THEN unit_other ELSE COALESCE(unit,'') END AS unit,
+CASE WHEN department='其他' AND COALESCE(department_other,'')<>'' THEN department_other ELSE COALESCE(department,'') END AS department,
+CASE WHEN team='其他' AND COALESCE(team_other,'')<>'' THEN team_other ELSE COALESCE(team,'') END AS team,
+unit_other,
+department_other,
+team_other,
+created_at
+"""
+
+
+def _display_choice(value: str, other_value: str = "") -> str:
+    value = (value or "").strip()
+    other_value = (other_value or "").strip()
+    if value == "其他" and other_value:
+        return other_value
+    return value
+
+
+def _record_select_sql() -> str:
+    return """
+    SELECT
+        r.*,
+        u.gender AS gender,
+        CASE WHEN u.unit='其他' AND COALESCE(u.unit_other,'')<>'' THEN u.unit_other ELSE COALESCE(u.unit,'') END AS unit,
+        CASE WHEN u.department='其他' AND COALESCE(u.department_other,'')<>'' THEN u.department_other ELSE COALESCE(u.department,'') END AS department,
+        CASE WHEN u.team='其他' AND COALESCE(u.team_other,'')<>'' THEN u.team_other ELSE COALESCE(u.team,'') END AS team
+    FROM trip_records r
+    LEFT JOIN users u ON u.username = r.username
+    """
